/* ========== 全局 CSS 变量 ========== */
page {
  --bg: #0d1117;
  --card: #161b22;
  --border: #30363d;
  --text: #e6edf3;
  --text-secondary: #8b949e;
  --accent: #58a6ff;
  --accent-green: #3fb950;
  --accent-orange: #d2991d;
  --input-bg: #0d1117;
  --danger: #f85149;
  --radius: 16px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Microsoft YaHei", "Helvetica Neue", sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* 亮色主题 */
.theme-light {
  --bg: #f5f5f7;
  --card: #ffffff;
  --border: #e0e0e6;
  --text: #1d1d1f;
  --text-secondary: #86868b;
  --accent: #0071e3;
  --accent-green: #34c759;
  --accent-orange: #ff9f0a;
  --input-bg: #f5f5f7;
  --danger: #ff3b30;
}

/* 通用 */
.container {
  padding: 24px;
  max-width: 440px;
  margin: 0 auto;
}

/* 表单 */
.form-group {
  margin-bottom: 20px;
}

.form-group .label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 6px;
  letter-spacing: 0.3px;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: var(--input-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  transition: border-color 0.2s;
}

.input-wrapper input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text);
  font-size: 18px;
  font-weight: 600;
  padding: 14px 16px;
  outline: none;
  font-family: "SF Mono", "Menlo", monospace;
  letter-spacing: -0.3px;
  width: 100%;
}

.input-wrapper .unit {
  flex-shrink: 0;
  color: var(--text-secondary);
  font-size: 14px;
  padding-right: 14px;
  font-weight: 500;
}

/* picker 伪装成 select */
.picker-wrapper {
  display: flex;
  align-items: center;
  background: var(--input-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 16px;
  position: relative;
}

.picker-wrapper .picker-value {
  flex: 1;
  font-size: 16px;
  font-weight: 500;
  color: var(--text);
}

.picker-wrapper .picker-arrow {
  color: var(--text-secondary);
  font-size: 12px;
}

.form-row {
  display: flex;
  gap: 12px;
}

.form-row .form-group {
  flex: 1;
}

/* 按钮 */
.btn-primary {
  width: 100%;
  padding: 14px;
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 0.5px;
  margin-top: 8px;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-row {
  display: flex;
  gap: 10px;
}

.btn-secondary {
  flex: 1;
  padding: 12px;
  background: var(--card);
  color: var(--text-secondary);
  border: 1px solid var(--border);
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
}

.btn-danger {
  flex: 1;
  padding: 12px;
  background: transparent;
  color: var(--danger);
  border: 1px solid rgba(248, 81, 73, 0.3);
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
}

/* 预览 */
.preview {
  text-align: center;
  margin-top: 20px;
  padding: 16px;
  background: rgba(63, 185, 80, 0.06);
  border: 1px solid rgba(63, 185, 80, 0.15);
  border-radius: 10px;
}

.preview .preview-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.preview .preview-value {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent-green);
}

.preview .preview-detail {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 6px;
}

/* 卡片 */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

/* 时间卡片 */
.time-card {
  padding: 20px 24px 16px;
  text-align: center;
  margin-bottom: 16px;
}

.time-card .time-label {
  font-size: 12px;
  color: var(--text-secondary);
  letter-spacing: 1px;
  margin-bottom: 4px;
}

.time-card .current-time {
  font-size: 48px;
  font-weight: 700;
  font-family: "SF Mono", "Menlo", monospace;
  letter-spacing: -1px;
  color: var(--text);
}

.time-card .current-date {
  font-size: 14px;
  color: var(--text-secondary);
  margin-top: 2px;
}

.time-card .countdown {
  font-size: 13px;
  color: var(--accent);
  margin-top: 8px;
  font-weight: 500;
}

/* 收入卡片 */
.earnings-card {
  padding: 24px;
  text-align: center;
  margin-bottom: 16px;
}

.earnings-card .earnings-label {
  font-size: 13px;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.earnings-card .earnings-amount {
  font-size: 56px;
  font-weight: 700;
  color: var(--accent-green);
  font-family: "SF Mono", "Menlo", monospace;
  letter-spacing: -1.5px;
  line-height: 1;
}

.earnings-card .earnings-amount .yen {
  font-size: 28px;
  margin-right: 4px;
  vertical-align: top;
}

.earnings-card .earnings-amount .decimal {
  font-size: 36px;
}

.earnings-card .earnings-rate {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 10px;
}

.earnings-card .progress-bar-wrap {
  margin-top: 16px;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}

.earnings-card .progress-bar-fill {
  height: 100%;
  background: var(--accent-green);
  border-radius: 2px;
  transition: width 0.5s ease;
}

.earnings-card .work-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 12px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
}

.status-dot.running {
  background: var(--accent-green);
  animation: pulse 2s infinite;
}

.status-dot.paused {
  background: var(--accent-orange);
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* 统计行 */
.stats-row {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
}

.stat-card {
  flex: 1;
  padding: 14px 12px;
  text-align: center;
}

.stat-card .stat-label {
  font-size: 11px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.stat-card .stat-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
}

.stat-card .stat-value.small {
  font-size: 18px;
}

/* 主题切换按钮 */
.theme-toggle {
  position: fixed;
  top: 16px;
  right: 16px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--card);
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
}

/* setup 标题 */
.setup-screen h1 {
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 6px;
  letter-spacing: -0.3px;
}

.setup-screen .subtitle {
  text-align: center;
  color: var(--text-secondary);
  font-size: 14px;
  margin-bottom: 28px;
}